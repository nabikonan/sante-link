# DiabSuivi — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env dans Git

# ── Base de données ───────────────────────────────────────────
DB_HOST=localhost
DB_NAME=diabsuivi
DB_USER=diabsuivi_user
DB_PASS=VotreMotDePasseSecurise123!

# ── URL de l'application ──────────────────────────────────────
APP_URL=http://localhost/diabsuivi/project

# ── Email (PHPMailer / SMTP) ──────────────────────────────────
# Gmail : activez "Mot de passe d'application" dans votre compte Google
# Guide : https://support.google.com/accounts/answer/185833
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=votre.email@gmail.com
MAIL_PASS=votre_mot_de_passe_application
MAIL_FROM=noreply@diabsuivi.sn
MAIL_FROM_NAME=DiabSuivi

# ── SMS (Twilio) ──────────────────────────────────────────────
# Créez un compte sur https://www.twilio.com/try-twilio
# Récupérez Account SID et Auth Token dans votre console Twilio
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token_here
TWILIO_FROM=+12025551234
